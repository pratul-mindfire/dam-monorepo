{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./src/tests/*"]
    },
    "target": "ES2023"
  },
  "include": ["index.js", "src/**/*.js"]
}
